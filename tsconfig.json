{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "checkJs": true,
        "allowJs": true,
        "emitDeclarationOnly": false,
        "strict": true,
        "pretty": true,
        "declaration": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": false,
        "resolveJsonModule": false,
        "outDir": "dist",
        "isolatedModules": true,
        "noEmitOnError": true,
    },
    "include": ["src"],
    "exclude": [
        "node_modules",
        "test"
    ]
}